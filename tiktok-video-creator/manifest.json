{
  "manifest_version": 3,
  "name": "TikTok Video Creator",
  "description": "สร้าง prompt วิดีโอสินค้า TikTok, เปิด Google Flow, และจัดการผลลัพธ์จาก side panel",
  "version": "0.1.0",
  "permissions": [
    "storage",
    "sidePanel",
    "activeTab",
    "scripting",
    "downloads",
    "identity",
    "tabs",
    "notifications",
    "debugger",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://*.tiktok.com/*",
    "https://shop.tiktok.com/*",
    "https://open.tiktokapis.com/*",
    "https://labs.google/*",
    "https://labs.google.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "content_scripts": [
    {
      "js": [
        "content/flow-automation.js"
      ],
      "matches": [
        "https://labs.google/fx/tools/flow*",
        "https://labs.google/fx/*/tools/flow*",
        "https://labs.google.com/fx/tools/flow*",
        "https://labs.google.com/fx/*/tools/flow*"
      ],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "js": [
        "content/tiktok-interceptor-inject.js"
      ],
      "matches": [
        "https://www.tiktok.com/tiktokstudio*",
        "https://www.tiktok.com/tiktok-studio*"
      ],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "js": [
        "content/tiktok-interceptor-receiver.js"
      ],
      "matches": [
        "https://www.tiktok.com/tiktokstudio*",
        "https://www.tiktok.com/tiktok-studio*"
      ],
      "run_at": "document_start",
      "world": "ISOLATED",
      "all_frames": false
    },
    {
      "js": [
        "content/tiktok-post-loader.js"
      ],
      "matches": [
        "https://www.tiktok.com/tiktokstudio*",
        "https://www.tiktok.com/tiktok-studio*"
      ],
      "run_at": "document_idle",
      "world": "ISOLATED",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/tiktok-post.js",
        "content/tiktok-studio-automation.js"
      ],
      "matches": [
        "https://www.tiktok.com/*"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "TikTok Video Creator",
    "default_icon": {
      "16": "assets/icon16.png",
      "48": "assets/icon48.png",
      "128": "assets/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://shop.tiktok.com https://open.tiktokapis.com https://generativelanguage.googleapis.com https://*.ibyteimg.com https://labs.google https://labs.google.com;"
  }
}
